{
  "annotations": { "list": [] },
  "editable": true,
  "title": "OJP Overview (starter)",
  "uid": "ojp-overview",
  "schemaVersion": 39,
  "version": 1,
  "tags": ["ojp"],
  "templating": { "list": [] },
  "time": { "from": "now-15m", "to": "now" },
  "panels": [
    {
      "type": "timeseries",
      "title": "OJP server up",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 0 },
      "targets": [
        { "expr": "up{job=\"ojp-server\"}", "legendFormat": "up" }
      ],
      "fieldConfig": { "defaults": {}, "overrides": [] }
    },
    {
      "type": "timeseries",
      "title": "Connection pool (active / idle) — adjust metric names to your OJP version",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 6 },
      "targets": [
        { "expr": "hikaricp_connections_active", "legendFormat": "active" },
        { "expr": "hikaricp_connections_idle", "legendFormat": "idle" }
      ],
      "fieldConfig": { "defaults": {}, "overrides": [] }
    },
    {
      "type": "timeseries",
      "title": "Query admission / throttling — adjust to your OJP version's metrics",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 14 },
      "targets": [
        { "expr": "rate(ojp_queries_total[1m])", "legendFormat": "queries/s" }
      ],
      "fieldConfig": { "defaults": {}, "overrides": [] }
    }
  ]
}
